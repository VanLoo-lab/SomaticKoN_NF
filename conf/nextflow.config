nextflow.enable.dsl = 2

params {
  // I/O
  pairs_tsv   = null // Pair manifest (TSV/CSV): pair_id,tumor_id,tumor_bam,normal_id,normal_bam,gender
  samplesheet = null // Legacy alias for pairs_tsv
  outdir      = "/rsrch6/home/genetics/zzhang18/projects/WGS_pipeline/scripts/pipelines/tests/nf_out"
  workdir     = null

  // references resolver
  ref         = "hg38"
  refdir      = "/rsrch6/home/genetics/zzhang18/projects/WGS_pipeline/scripts/project-run/refs"
  seq         = "WGS"

  // script locations
  // base pipeline directory (override with --pipeline)
  pipeline    = params.pipeline ?: projectDir
  binDir      = "${params.pipeline}/modules/somatic"
  resolveRefs = "${params.pipeline}/bin/lib/resolve_refs.sh"
  libDir      = "${params.pipeline}/bin/lib"
  envDir      = "${params.pipeline}/envs"
  
  // compute knobs
  threads     = 10
  chroms      = (1..22).collect{ "chr${it}" } + ["chrX"]

  // consensus knobs
  k_range     = "1:3"
  k_pick      = 2

  // conda env directory
  condaEnvDir = "/rsrch6/home/genetics/zzhang18/.conda/envs"

  // normal ID hint
  normal_id   = null
}

process {
  shell = ['/bin/bash','-euo','pipefail']
  executor = 'lsf'
  queue = 'cgel'

  clusterOptions = { "" }

  cpus   = 1
  memory = '100 GB'
  time   = '2h'

  // Let each caller fail without cancelling the others.
  withName: 'MUTECT2_SCATTER|MUTECT2_GATHER|MUSE2_CALL|STRELKA2_CALL' {
    errorStrategy = 'ignore'
  }

}

profiles {
  lsf { process.executor = 'lsf' }
  local { process.executor = 'local' }
}

// Use per-job memory limit; do not divide by cpus (LSF).
executor.perJobMemLimit = true

conda {
  enabled = true
}

timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline.html"; overwrite = true }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report.html"; overwrite = true }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/trace.tsv"; overwrite = true }
dag      { enabled = true; file = "${params.outdir}/pipeline_info/dag.svg"; overwrite = true }
